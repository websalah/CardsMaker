@model List<PersonResponse>

@{
    ViewData["Title"] = "All Cards";
}

<div class="page-header">
    <h1>Your Cards</h1>
    <p>Manage your personal contact cards</p>
</div>

@if (Model.Count == 0)
{
    <div class="empty-state">
        <div class="icon">&#9830;</div>
        <h2>No cards yet</h2>
        <p>Create your first personal card to get started.</p>
        <a asp-action="Create" class="btn btn-primary">+ Create Card</a>
    </div>
}
else
{
    <div class="cards-grid">
        @foreach (var person in Model)
        {
            <a asp-action="Details" asp-route-id="@person.Id" class="person-card">
                <div class="card-name">@person.Name</div>
                @if (!string.IsNullOrEmpty(person.LogoPath))
                {
                    <img class="logo" src="@person.LogoPath" alt="Logo" />
                }
                else
                {
                    <img class="logo" src="~/img/logo.png" alt="Logo" />
                }
                <div class="card-job">@person.JobTitle</div>
                <div class="card-detail">
                    <span class="label"><i class="fa-solid fa-at"></i></span>
                    <span>@person.Email</span>
                </div>
                <div class="card-detail">
                    <span class="label"><i class="fa-solid fa-globe"></i></span>
                    <span>@person.Website</span>
                </div>
                <div class="card-detail">
                    <span class="label"><i class="fa-solid fa-phone"></i></span>
                    <span>@person.PhoneNumber</span>
                </div>
                <div class="card-detail">
                    <span class="label"><i class="fa-solid fa-location-crosshairs"></i></span>
                    <span>@person.Address</span>
                </div>
                <div class="card-detail">
                    <span class="label"><i class="fa-solid fa-house"></i></span>
                    <span>@person.City</span>
                </div>
            </a>
            <div class="card-actions">
                <button class="btn btn-secondary"><i class="fa-solid fa-arrow-down"></i> Download</button>
            </div>
        }
    </div>
}