@model PersonResponse

@{
    ViewData["Title"] = Model.Name + " — Card Details";
}

<div class="page-header">
    <h1>Card Details</h1>
</div>

<div class="details-card">
    <div class="details-name">@Model.Name</div>
    <div class="details-job">@Model.JobTitle</div>

    <div class="details-row">
        <div class="details-label"><i class="fa-solid fa-at"></i></div>
        <div class="details-value">@Model.Email</div>
    </div>

    <div class="details-row">
        <div class="details-label"><i class="fa-solid fa-globe"></i></div>
        <div class="details-value">@Model.Website</div>
    </div>

    <div class="details-row">
        <div class="details-label"><i class="fa-solid fa-phone"></i></div>
        <div class="details-value">@Model.PhoneNumber</div>
    </div>

    <div class="details-row">
        <div class="details-label"><i class="fa-solid fa-location-crosshairs"></i></div>
        <div class="details-value">@(Model.Address ?? "—")</div>
    </div>

    <div class="details-row">
        <div class="details-label"><i class="fa-solid fa-house"></i></div>
        <div class="details-value">@Model.City</div>
    </div>

    <div class="details-actions">
        <a asp-action="Index" class="btn btn-secondary">&larr; Back to All Cards</a>
    </div>
</div>
