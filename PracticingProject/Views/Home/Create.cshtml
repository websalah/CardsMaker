@model PersonRequest

@{
    ViewData["Title"] = "Create Card";
}

<div class="page-header">
    <h1>Create New Card</h1>
    <p>Fill in the details below to create a personal card</p>
</div>

<div class="form-card">
    <form asp-action="Create" method="post" enctype="multipart/form-data">
        <div class="form-group">
            <label asp-for="Name"></label>
            <input asp-for="Name" placeholder="e.g. Ahmed Ali" />
            <span asp-validation-for="Name" class="text-danger"></span>
        </div>

        <div class="form-group">
            <label asp-for="Email"></label>
            <input asp-for="Email" type="email" placeholder="e.g. ahmed@example.com" />
            <span asp-validation-for="Email" class="text-danger"></span>
        </div>

        <div class="form-group">
            <label asp-for="Website"></label>
            <input asp-for="Website" type="text" placeholder="e.g. www.example.com" />
            <span asp-validation-for="Website" class="text-danger"></span>
        </div>

        <div class="form-group">
            <label asp-for="PhoneNumber"></label>
            <input asp-for="PhoneNumber" type="tel" placeholder="e.g. +964 770 123 4567" />
            <span asp-validation-for="PhoneNumber" class="text-danger"></span>
        </div>

        <div class="form-group">
            <label asp-for="Address"></label>
            <input asp-for="Address" placeholder="e.g. 123 Main St, City" />
        </div>

        <div class="form-group">
            <label asp-for="City"></label>
            <input asp-for="City" placeholder="e.g. Baghdad" />
        </div>
        <div class="form-group">
            <label asp-for="JobTitle"></label>
            <input asp-for="JobTitle" placeholder="e.g. Software Engineer" />
        </div>
        <div class="form-group">
            <label asp-for="Logo">Card Logo</label>
            <input asp-for="Logo" type="file" accept="image/*" class="file-input" />
        </div>

        <div class="form-actions">
            <button type="submit" class="btn btn-primary">Create Card</button>
            <a asp-action="Index" class="btn btn-secondary">Cancel</a>
        </div>
    </form>
</div>
